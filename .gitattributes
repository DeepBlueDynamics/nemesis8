# Force Unix line endings for shell scripts regardless of OS
*.sh    text eol=lf
*.bash  text eol=lf

# Windows scripts keep CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Rust/TOML/config — normalize to LF
*.rs    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Binaries
*.png   binary
*.jpg   binary
*.gz    binary
*.zip   binary
